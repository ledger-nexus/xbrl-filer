// xbrl-filer Prisma schema.
//
// Two halves (same pattern as recon / revenue-rec):
//
//   1. ledger-core models xbrl-filer QUERIES (Tenant, TenantMembership,
//      User, LegalEntity, Book, Account, JournalEntry, JournalLine).
//      These mirror the canonical definitions in ledger-core's schema —
//      column-for-column, relations trimmed to the mirrored set. xbrl-filer
//      does NOT migrate these tables; ledger-core owns them. This mirror
//      was GENERATED from ledger-core's schema at v1.25 (2026-07-16) —
//      re-generate on upstream schema change, never hand-drift.
//
//   2. xbrl-filer models this repo OWNS (XbrlTaxonomy, XbrlConcept,
//      XbrlConceptMapping, XbrlFiling, XbrlFilingFact). Schema changes to
//      the shared DB are applied via a REVIEWED `prisma migrate diff`
//      script (see docs/ARCHITECTURE.md) — never a blind `db push`, which
//      could mutate ledger-core-owned tables if the mirror drifts.
//
// The repos share one Postgres database (same DATABASE_URL). xbrl-filer is
// a READ-ONLY consumer of the ledger: it never writes journal entries —
// XBRL is reporting, not transacting.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// ledger-core mirror — DO NOT EDIT without re-syncing from ledger-core
// =========================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum BookBasis {
  US_GAAP
  US_TAX
  IFRS
  MGMT
  STATUTORY
}

enum EntryStatus {
  DRAFT
  POSTED
  VOID
  REVERSED
}

enum JournalSource {
  MANUAL // entered by a human via the UI
  SEED // loaded from seed data
  SYSTEM // posted by another module (e.g. rev rec engine)
  AI_APPROVED // AI suggested, human approved (used in recon project)
  IMPORT // ERP import (companion to source_system lineage)
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum OwnerType {
  USER
  QUEUE
}

enum TenantRole {
  OWNER // cannot be removed; can delete the tenant
  ADMIN // full read+write+admin (period close, user lifecycle)
  MEMBER // read+write, no admin actions
}

enum TranslationCategory {
  CURRENT_RATE
  HISTORICAL
  WEIGHTED_AVG
  EXCLUDED
}

model Tenant {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String @unique // url-safe, e.g. "acme-co"
  name        String
  ownerUserId String @db.Uuid

  memberships TenantMembership[]

  // Backrefs from tenant-scoped domain models. Listed here so Prisma can
  // resolve the relations on the other side. Cascading delete is OFF by
  // default — soft delete is the intended path for tenant offboarding
  // (see docs/multi-tenancy.md "Open questions").
  legalEntities  LegalEntity[]
  accounts       Account[]
  journalEntries JournalEntry[]
  journalLines   JournalLine[]
  // BlackLine arc Phase 1: account-reconciliation workflow.
  // BlackLine arc Phase 2: close-task calendar.
  // BlackLine arc Phase 3: flux / variance analysis.
  // Notifications arc: per-tenant Slack/etc channels for close alerts.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([ownerUserId])
  @@map("tenant")
}

model TenantMembership {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String     @db.Uuid
  userId   String     @db.Uuid
  role     TenantRole @default(MEMBER)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_membership")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  displayName   String
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?

  // Multi-tenancy: a User can belong to N Tenants via TenantMembership.
  // User itself is global (no tenantId) — login lookup is global by email.
  tenantMemberships TenantMembership[]

  // BlackLine arc Phase 1: a user can be the preparer on N recons, the
  // reviewer on N recons, and the uploader of N attachments. CPA
  // segregation of duties means preparer != reviewer on the same recon
  // (enforced at the Server Action layer, not the schema).
  // BlackLine arc Phase 2: close-task calendar. A user can own N close
  // tasks (assigned executor), complete N, and author N comments.
  // Notifications arc: which channels did this user create.
  // BlackLine arc Phase 3: flux / variance analysis.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_user")
}

model LegalEntity {
  // Back-relations for xbrl-filer-owned tables (this repo only)
  xbrlConceptMappings XbrlConceptMapping[]
  xbrlFilings         XbrlFiling[]

  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // tenantId is nullable during migration (Phase 1); Phase 4 backfills
  // remaining rows, scopes all queries, and applies NOT NULL.
  tenantId       String        @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // Phase 4b: code is unique PER tenant. Two tenants can both own
  // an entity coded "ACME" — collisions are isolated by tenantId.
  code           String
  name           String
  parentEntityId String?       @db.Uuid
  parent         LegalEntity?  @relation("EntityHierarchy", fields: [parentEntityId], references: [id])
  children       LegalEntity[] @relation("EntityHierarchy")

  // The currency this entity reports in. Each book may override for reporting.
  functionalCurrencyId String

  // Lineage — null for natively-created entities; populated on ERP import.
  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  accounts       Account[]
  journalEntries JournalEntry[]
  // BlackLine arc Phase 2: close-task calendar.
  // BlackLine arc Phase 3: flux / variance analysis.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("legal_entity")
}

model Book {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String    @unique // e.g. "US_GAAP", "US_TAX", "IFRS", "MGMT"
  name                String
  // The accounting basis. Drives default behavior in posting rules + reports.
  basis               BookBasis
  // Reporting currency for THIS book. Functional currency lives on LegalEntity.
  // Permits e.g. a US entity with a USD functional ledger but an EUR-reported IFRS book.
  reportingCurrencyId String

  isActive   Boolean @default(true)
  extensions Json?

  journalEntries JournalEntry[]
  // BlackLine arc Phase 2: close-task calendar.
  // BlackLine arc Phase 3: flux / variance analysis.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("book")
}

model Account {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // entityId null = shared across all entities (consolidated chart).
  // Set to a value = entity-specific account.
  entityId String?      @db.Uuid
  entity   LegalEntity? @relation(fields: [entityId], references: [id])

  // Human-readable code (e.g. "1000" for Cash). NOT a source-system primary key.
  // Convention: 1xxx Assets, 2xxx Liabilities, 3xxx Equity, 4xxx Revenue, 5xxx-9xxx Expenses.
  code             String
  name             String
  type             AccountType
  normalBalance    NormalBalance
  subtype          String? // e.g. "CASH", "AR_TRADE", "INVENTORY_RAW"
  isContra         Boolean       @default(false)
  isControlAccount Boolean       @default(false) // true for AR/AP control accounts
  isBank           Boolean       @default(false)

  // ASC 830 / IAS 21: monetary accounts (cash, receivables, payables, debt)
  // hold a fixed number of currency units, so a foreign-currency balance is
  // re-measured to the functional currency at the period-end CLOSE rate and
  // the delta hits FX gain/loss. Non-monetary accounts (inventory, fixed
  // assets, prepaids, equity) stay at historical rate and are NOT revalued.
  // The revaluation engine walks accounts where isMonetary = true.
  isMonetary Boolean @default(false)

  // FX Phase 4 — ASC 830 translation method for CONSOLIDATION (distinct
  // from isMonetary, which drives period-end remeasurement). Nullable so
  // existing single-currency installations don't need a backfill; the
  // consolidation translator defaults to CURRENT_RATE when null. New
  // chart-of-accounts rows + seed paths set this explicitly per category.
  translationCategory TranslationCategory?

  parentAccountId String?   @db.Uuid
  parent          Account?  @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  children        Account[] @relation("AccountHierarchy")

  // Books this account applies to. Empty = applies to all books.
  // e.g. ["US_TAX"] for a tax-only account; empty for a normal account.
  bookScope String[] @default([])

  active Boolean @default(true)

  // BlackLine arc Phase 1: per-account override of the tenant default.
  // - requiresReconReview: null = inherit ReconciliationConfig.defaultRequiresReview.
  //   true = always preparer→reviewer chain. false = single sign-off OK.
  // - reconTolerance: null = inherit tenant default (typically 0 = must tie out
  //   exactly). Non-null = $-amount diff allowed before marking EXCEPTION.
  //   Used by cash accounts where rounding differences are common.
  requiresReconReview Boolean?
  reconTolerance      Decimal? @db.Decimal(20, 4)

  lines JournalLine[]
  // BlackLine arc Phase 3: flux / variance analysis.

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, code])
  @@index([type])
  @@index([tenantId])
  @@map("account")
}

model JournalEntry {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // entryNumber is a human-readable sequential ID, unique per (entity, book).
  // Format: ENTITY-BOOK-NNNNN (e.g. NORTHWIND-US_GAAP-00001).
  // Phase 4b: unique per [tenantId, entryNumber] — each tenant can have
  // its own NORTHWIND-US_GAAP-00001 without colliding.
  entryNumber String

  entityId String      @db.Uuid
  entity   LegalEntity @relation(fields: [entityId], references: [id])
  bookId   String      @db.Uuid
  book     Book        @relation(fields: [bookId], references: [id])

  // periodId is resolved at posting time from the document/posting date and
  // the entity's fiscal calendar. Null only allowed for entries dated before
  // any defined period (historical pre-go-live data).
  periodId String? @db.Uuid

  // Document date = when the transaction is dated (invoice date).
  // Posting date = when it hit the ledger (often same; can differ for backdated entries).
  documentDate DateTime @db.Date
  postingDate  DateTime @db.Date

  memo String

  // Header currency = the transaction's natural currency. fxRate translates
  // it to the book's reporting currency. Per-line currency is allowed in
  // edge cases (intercompany) but defaults to the header.
  currencyId String
  fxRate     Decimal @default(1) @db.Decimal(20, 10)

  source JournalSource @default(MANUAL)
  status EntryStatus   @default(POSTED)

  reversalOfId String?        @db.Uuid
  reversalOf   JournalEntry?  @relation("Reversal", fields: [reversalOfId], references: [id])
  reversedBy   JournalEntry[] @relation("Reversal")

  // Lineage — non-negotiable per spec. Populated on every ERP import.
  sourceSystem     String? // "QBO", "NETSUITE", "INTACCT", ...
  sourceRecordType String? // "Invoice", "Bill", "JournalEntry", ...
  sourceRecordId   String? // the source system's ID (NEVER reused as our PK)
  sourcePayload    Json? // frozen raw original
  mappingVersion   String?
  extensions       Json?

  lines JournalLine[]

  // Sub-ledger backrefs — entries that opened or applied to sub-ledger items.

  // Ownership + audit. ownerId is the default-responsible-party; defaults to
  // createdBy at insert and only changes via explicit reassignment (manual or
  // rule-fired). In ERP modules, ownerId is informational/workflow — module
  // permissions handle access control, NOT this field. See
  // docs/ownership-and-rules.md for the full semantic.
  ownerId              String?   @db.Uuid
  ownerType            OwnerType @default(USER)
  updatedBy            String?
  updatedAt            DateTime  @default(now()) @updatedAt
  // When set, the reassignment-rules engine SKIPS this record. Cleared
  // explicitly by an admin or by a state transition; never auto-cleared.
  reassignmentLockedAt DateTime?

  createdAt DateTime @default(now())
  createdBy String?

  // Backref to ownership events.

  // Backref to inline notes (review comments, follow-up flags).

  @@unique([tenantId, entryNumber])
  @@index([ownerId])
  @@index([entityId, bookId, documentDate])
  @@index([entityId, bookId, periodId])
  @@index([sourceSystem, sourceRecordType, sourceRecordId])
  @@index([tenantId, postingDate])
  @@map("gl_entry_header")
}

model JournalLine {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // tenantId denormalized from the parent JournalEntry for query speed.
  // Always equals entry.tenantId; enforced in postJournalEntry.
  tenantId  String       @db.Uuid
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  entryId   String       @db.Uuid
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo    Int // 1-based, position within entry
  accountId String       @db.Uuid
  account   Account      @relation(fields: [accountId], references: [id])

  // Sub-ledger keys — nullable. When populated, the entry contributes to a
  // sub-ledger lifecycle (e.g. partyId set on an AR line opens/applies an
  // AR open item). The open-item tables themselves arrive in the next batch.
  partyId String? @db.Uuid
  itemId  String? @db.Uuid

  // Layer 3 — dimension engine. Nullable until the first ERP import that
  // carries class/department/location dimensions.
  dimensionSetId String? @db.Uuid

  // taxCodeId — slot. TaxCode table arrives with the document layer in a
  // consumer repo. String form here to avoid a meaningless empty table now.
  taxCodeId String?

  // The canonical debit/credit pair in the BOOK's reporting currency.
  // XOR constraint enforced at the DB layer (migration SQL).
  debit  Decimal @default(0) @db.Decimal(18, 4)
  credit Decimal @default(0) @db.Decimal(18, 4)

  // Transaction-currency view (signed: debit positive, credit negative).
  // = (debit - credit) for single-currency. Diverges when the line is in
  // a non-functional currency (intercompany, FX gains/losses).
  transactionAmount     Decimal @default(0) @db.Decimal(18, 4)
  transactionCurrencyId String?

  // Reporting-currency view (signed). Equals functional when the book's
  // reporting currency = the entity's functional currency.
  reportingAmount     Decimal @default(0) @db.Decimal(18, 4)
  reportingCurrencyId String?

  description String?
  extensions  Json?

  @@unique([entryId, lineNo])
  @@index([entryId])
  @@index([accountId])
  @@index([partyId])
  @@index([tenantId])
  @@map("gl_entry_line")
}

// =========================================================================
// xbrl-filer owned models
// =========================================================================

enum XbrlPeriodType {
  INSTANT
  DURATION
}

enum XbrlBalance {
  DEBIT
  CREDIT
}

enum XbrlFilingStatus {
  DRAFT
  REVIEWED
  FILED
  AMENDED
}

// A taxonomy release (e.g. us-gaap 2024). v1 seeds ONE row with a
// hand-curated concept subset; a full taxonomy import is v2 work.
model XbrlTaxonomy {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  namespace     String // xmlns for facts, e.g. http://fasb.org/us-gaap/2024
  version       String
  schemaRefHref String // link:schemaRef target (published entry point)
  prefix        String               @default("us-gaap")
  concepts      XbrlConcept[]
  mappings      XbrlConceptMapping[]
  filings       XbrlFiling[]
  createdAt     DateTime             @default(now())

  @@unique([namespace, version])
  @@map("xbrl_taxonomy")
}

// Denormalized concept catalog. periodType/balance drive aggregation:
// INSTANT = cumulative balance through periodEnd; DURATION = activity in
// [periodStart, periodEnd]. balance decides the sign (DEBIT: D-C, CREDIT: C-D).
model XbrlConcept {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taxonomyId String               @db.Uuid
  taxonomy   XbrlTaxonomy         @relation(fields: [taxonomyId], references: [id])
  qname      String // e.g. "us-gaap:Assets"
  label      String
  periodType XbrlPeriodType
  balance    XbrlBalance
  mappings   XbrlConceptMapping[]
  createdAt  DateTime             @default(now())

  @@unique([taxonomyId, qname])
  @@map("xbrl_concept")
}

// The judgment-laden artifact: which account codes roll up into which
// concept, per (tenant, entity, taxonomy). Mapping is by account CODE
// (stable, human-legible) — resolution to balances happens at generate
// time against the live ledger.
model XbrlConceptMapping {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  entityId    String       @db.Uuid
  entity      LegalEntity  @relation(fields: [entityId], references: [id])
  taxonomyId  String       @db.Uuid
  taxonomy    XbrlTaxonomy @relation(fields: [taxonomyId], references: [id])
  conceptId   String       @db.Uuid
  concept     XbrlConcept  @relation(fields: [conceptId], references: [id])
  accountCode String
  createdBy   String?
  createdAt   DateTime     @default(now())

  @@unique([tenantId, entityId, taxonomyId, conceptId, accountCode])
  @@index([tenantId, entityId, taxonomyId])
  @@map("xbrl_concept_mapping")
}

// One generated instance document. generatedXml is immutable once status
// leaves DRAFT (enforced in the action layer; v1 only creates DRAFT).
model XbrlFiling {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String           @db.Uuid
  entityId         String           @db.Uuid
  entity           LegalEntity      @relation(fields: [entityId], references: [id])
  bookCode         String
  taxonomyId       String           @db.Uuid
  taxonomy         XbrlTaxonomy     @relation(fields: [taxonomyId], references: [id])
  status           XbrlFilingStatus @default(DRAFT)
  documentType     String? // e.g. "FS" (v1), "10-Q"/"10-K" (v2, SEC)
  cik              String? // SEC Central Index Key; entity code used when absent
  periodStart      DateTime
  periodEnd        DateTime
  generatedXml     String?
  validationReport Json?
  generatedAt      DateTime?
  createdBy        String?
  facts            XbrlFilingFact[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([tenantId, entityId])
  @@map("xbrl_filing")
}

// Per-fact audit trail: which concept, what value, and exactly which
// accounts contributed what amount — the tie-out from instance document
// back to the ledger.
model XbrlFilingFact {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filingId             String     @db.Uuid
  filing               XbrlFiling @relation(fields: [filingId], references: [id], onDelete: Cascade)
  conceptQname         String
  contextRef           String // "C_I" (instant) | "C_D" (duration)
  value                Decimal    @db.Decimal(20, 4)
  contributingAccounts Json // { accountCode: signed amount }
  createdAt            DateTime   @default(now())

  @@index([filingId])
  @@map("xbrl_filing_fact")
}
